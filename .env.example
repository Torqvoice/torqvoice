# Database (PostgreSQL)
# Use your real host, user, password, and database name.
# If you use a pooler (e.g. PgBouncer / Supabase :6543), put that URL here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Direct URL for Prisma migrations (non-pooled / bypasses PgBouncer when required)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Authentication (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET="your-secret-here"

# App URL (used by the app and Better Auth)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Optional ---
# SaaS mode: subscription plans and Stripe billing (see src/lib/features.ts)
# TORQVOICE_MODE=cloud
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_MODE=live
# STRIPE_PRO_PRICE_ID=
# STRIPE_ENTERPRISE_PRICE_ID=

# Analytics (src/app/layout.tsx)
# POSTHOG_KEY=
# POSTHOG_HOST=

# Protected cron routes (src/app/api/v1/cron/*)
# CRON_SECRET=

# SMTP fallback when org email is not configured (src/lib/email.ts)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=
# SMTP_SECURE=false
# SMTP_REJECT_UNAUTHORIZED=true

# License validation base URL (self-hosted; defaults to https://torqvoice.com)
# NEXT_PUBLIC_TORQVOICE_COM_URL=
